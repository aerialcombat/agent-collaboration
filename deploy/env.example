# /etc/agent-collab/env — secrets + tunables for agent-collab systemd services.
#
# Copy this file to /etc/agent-collab/env, fill in values, and set perms:
#   sudo cp env.example /etc/agent-collab/env
#   sudo chown root:agent-collab /etc/agent-collab/env
#   sudo chmod 640 /etc/agent-collab/env
#
# Systemd reads this via `EnvironmentFile=` on agent-collab-peer-web.service
# and agent-collab-daemon@.service. Lines starting with # are ignored.
# Values must be KEY=value with no shell expansion (systemd limitation).

# ---- Anthropic ------------------------------------------------------------
# Required for Claude Code CLI spawn path. Get one at console.anthropic.com.
ANTHROPIC_API_KEY=

# Optional: route Claude through a custom base URL (for self-hosted proxy).
# ANTHROPIC_BASE_URL=

# ---- pi provider keys -----------------------------------------------------
# pi routes to third-party providers. Only set the ones you actually use.
# Omit the rest — pi daemon configs that don't need them will ignore.

# OpenAI (pi --provider openai-codex or similar)
# OPENAI_API_KEY=

# Google Gemini
# GEMINI_API_KEY=

# DeepInfra (qwen, deepseek, etc.)
# DEEPINFRA_API_KEY=

# zai / glm
# ZAI_API_KEY=

# ---- agent-collab tunables ------------------------------------------------

# Max turns per pair-room before peer-send starts refusing. Default 100
# in the Python CLI; 500 leaves plenty of headroom for long design
# conversations. Tune down if rooms spiral.
# AGENT_COLLAB_MAX_PAIR_TURNS=100

# Override the SQLite DB location. Default is
# ~/.agent-collab/sessions.db on the agent-collab user's home.
# AGENT_COLLAB_INBOX_DB=/var/lib/agent-collab/.agent-collab/sessions.db

# Force peer-web to use the Python implementation instead of the Go
# binary (for bug-report reproducibility). Leave unset in production.
# AGENT_COLLAB_WEB_IMPL=python

# ---- Daemon overrides (rarely needed) -------------------------------------

# Per-batch ack timeout; the daemon waits this long for the spawned
# CLI to acknowledge receipt before sweeping the claim. Default 300s.
# AGENT_COLLAB_ACK_TIMEOUT=300

# Sweep TTL for orphan-claim reaping. Default 600s.
# AGENT_COLLAB_SWEEP_TTL=600
