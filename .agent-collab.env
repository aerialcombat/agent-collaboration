AGENT_COLLAB_GUIDE=AGENT-COLLABORATION.md
AGENT_COLLAB_REVIEW_DIR=.agent-collab/reviews
AGENT_COLLAB_DEFAULT_CHALLENGER=claude
AGENT_COLLAB_TIMEOUT_SECONDS=120
AGENT_COLLAB_CLAUDE_TIMEOUT_SECONDS=300
AGENT_COLLAB_CODEX_TIMEOUT_SECONDS=60
AGENT_COLLAB_GEMINI_TIMEOUT_SECONDS=120
AGENT_COLLAB_CLAUDE_EFFORT=low

# Peer inbox (optional overrides; defaults point under ~/.agent-collab/)
# AGENT_COLLAB_INBOX_DB=~/.agent-collab/sessions.db
# AGENT_COLLAB_PEER_INBOX_DB_SCRIPT=~/.agent-collab/scripts/peer-inbox-db.py
# AGENT_COLLAB_HOOK_LOG=~/.agent-collab/hook.log
