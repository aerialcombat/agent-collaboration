#!/usr/bin/env bash
# agent-collaboration managed command
set -euo pipefail

PROGRAM="$(basename "$0")"
MODE=""
CHALLENGER=""
GUIDE_OVERRIDE=""
REVIEW_DIR_OVERRIDE=""
OUT_OVERRIDE=""
EXTRA_PROMPT=""
TIMEOUT_OVERRIDE=""
DRY_RUN=0

CONFIG_FILE=""
CONFIG_GUIDE=""
CONFIG_REVIEW_DIR=""
CONFIG_DEFAULT_CHALLENGER=""
CONFIG_TIMEOUT_SECONDS=""
CONFIG_CLAUDE_TIMEOUT_SECONDS=""
CONFIG_CODEX_TIMEOUT_SECONDS=""
CONFIG_GEMINI_TIMEOUT_SECONDS=""
CONFIG_CLAUDE_EFFORT=""
CONFIG_INBOX_DB=""

REPO_ROOT=""
GUIDE_PATH=""
GUIDE_DISPLAY=""
REVIEW_DIR=""
REVIEW_FILE=""
PROMPT=""
INLINE_FILE_LIMIT_BYTES=$((40 * 1024))
INLINE_TOTAL_LIMIT_BYTES=$((200 * 1024))
TIMEOUT_SECONDS="300"
TIMEOUT_BACKEND=""
TIMEOUT_COMMAND=""
CLAUDE_EFFORT="low"
CLAUDE_USE_READ_TOOL=0

SCOPE_INPUTS=()
CONTEXT_INPUTS=()
SCOPE_PATHS=()
CONTEXT_PATHS=()
SCOPE_DISPLAY=()
CONTEXT_DISPLAY=()

usage() {
  cat <<'EOF'
Usage:
  agent-collab challenge --challenger claude|codex|gemini [options]
  agent-collab verify --challenger claude|codex|gemini [options]
  agent-collab session register [--label <l>] --agent claude|codex|gemini|pi
                                [--role <r>] [--session-key <k>]
                                [--pair-key <k> | --new-pair] [--force]
                                --label is optional — a memorable slug is
                                generated when omitted and printed on success.
                                --pair-key joins the room identified by <k>.
                                --new-pair mints a fresh room key and prints it.
  agent-collab session adopt --label <l> --session-id <claude-uuid>
                                Re-key an existing registration to a real
                                Claude session_id so the hook can resolve.
  agent-collab session close [--label <l>] [--session-key <k>]
  agent-collab session list [--all-cwds] [--include-stale] [--json]
  agent-collab peer send --to <label> [--as <label>] [--to-cwd <path>]
                         --message <text> | --message-file <path> | --message-stdin
  agent-collab peer broadcast [--as <label>] [--to <label>]...
                         --message <text> | --message-file <path> | --message-stdin
                                Fan-out to the current room (pair_key if
                                set, else cwd). Pass --to one or more
                                times to multicast to a subset. One inbox
                                row per recipient, one shared room turn.
  agent-collab peer receive [--as <label>] [--mark-read] [--since <iso8601>]
                            [--format hook|hook-json|plain|json]
  agent-collab peer list [--as <label>] [--include-stale] [--json]
  agent-collab peer watch [--as <label>] [--interval <sec>] [--only-new]
                                Live-tail inbox; blocks until Ctrl-C.
  agent-collab peer replay [--as <label>] [--since <iso>] [--out <path>]
                                Emit self-contained HTML transcript of
                                messages in the current cwd (or narrowed to
                                a label's conversations).
  agent-collab room create [--pair-key <k>]
                                Mint an empty room (no members yet).
                                Prints the pair_key. Peers join later via
                                `session register --pair-key <k>`. Pass
                                --pair-key to use a specific key instead
                                of minting a random slug.
  agent-collab peer reset (--to <label> | --pair-key <k> | --room-key <k>)
                                Clear termination flag + turn counter for
                                a room. Use after [[end]] or after hitting
                                the max-turns cap. --to resets a cwd-only
                                edge; --pair-key resets the shared room.
  agent-collab peer web [--port 8787] [--pair-key K | --only-pair-key K
                                | --cwd PATH]
                                Serve a live browser view. Go binary (if
                                built at go/bin/peer-web) renders a
                                multi-room index at /; --pair-key is a
                                deep-link shortcut, --only-pair-key locks
                                the server to one room. Falls back to the
                                Python single-scope viewer if the binary
                                is missing or AGENT_COLLAB_WEB_IMPL=python
                                is set. Blocks until Ctrl-C.
                                Default: http://127.0.0.1:8787.
  agent-collab help

Session-key discovery for peer-inbox (register and self-resolution):
  Register reads a session key from, in priority order:
    1. --session-key <k>
    2. $AGENT_COLLAB_SESSION_KEY
    3. $CLAUDE_SESSION_ID / $CODEX_SESSION_ID / $GEMINI_SESSION_ID
  If none are set, register errors. Claude hooks set $CLAUDE_SESSION_ID
  automatically via stdin JSON; other agents should export
  $AGENT_COLLAB_SESSION_KEY or pass --session-key.

Options:
  --challenger <claude|codex|gemini>  Agent to invoke for the review pass.
  --scope <path>               Scope plan or other primary task context. Repeatable.
  --context <path>             Additional changed-file or design context. Repeatable.
  --guide <path>               Override the repo-local collaboration guide path.
  --review-dir <path>          Directory for generated review files, relative to repo root.
  --out <path>                 Exact output file path, relative to repo root if not absolute.
  --prompt <text>              Extra instructions appended to the default prompt shape.
  --timeout-seconds <n>        Hard timeout for the challenger subprocess. Use 0 to disable.
  --dry-run                    Print the derived prompt and file paths without invoking a CLI.
  -h, --help                   Show this help.

Repo-local config:
  The command looks for a data-only .agent-collab.env file at the repo root.
  Supported keys:
    AGENT_COLLAB_GUIDE=AGENT-COLLABORATION.md
    AGENT_COLLAB_REVIEW_DIR=.agent-collab/reviews
    AGENT_COLLAB_DEFAULT_CHALLENGER=claude
    AGENT_COLLAB_TIMEOUT_SECONDS=300
    AGENT_COLLAB_CLAUDE_TIMEOUT_SECONDS=300
    AGENT_COLLAB_CODEX_TIMEOUT_SECONDS=300
    AGENT_COLLAB_GEMINI_TIMEOUT_SECONDS=300
    AGENT_COLLAB_CLAUDE_EFFORT=low
EOF
}

err() {
  echo "error: $*" >&2
  exit 1
}

warn() {
  echo "warn: $*" >&2
}

trim() {
  local value="$1"
  value="${value#"${value%%[![:space:]]*}"}"
  value="${value%"${value##*[![:space:]]}"}"
  printf '%s' "$value"
}

strip_optional_quotes() {
  local value="$1"

  if [[ "$value" == \"*\" && "$value" == *\" ]]; then
    value="${value:1:${#value}-2}"
  elif [[ "$value" == \'*\' && "$value" == *\' ]]; then
    value="${value:1:${#value}-2}"
  fi

  printf '%s' "$value"
}

detect_repo_root() {
  local dir="$PWD"

  while :; do
    if [[ -f "$dir/.agent-collab.env" || -f "$dir/AGENT-COLLABORATION.md" || -e "$dir/.git" ]]; then
      (cd "$dir" && pwd -P)
      return
    fi

    if [[ "$dir" == "/" ]]; then
      break
    fi

    dir="$(dirname "$dir")"
  done

  pwd -P
}

load_config() {
  local file="$1"
  local raw_line line key value

  [[ -f "$file" ]] || return 0

  CONFIG_FILE="$file"

  while IFS= read -r raw_line || [[ -n "$raw_line" ]]; do
    line="$(trim "$raw_line")"
    [[ -z "$line" || "$line" == \#* ]] && continue

    if [[ "$line" != *=* ]]; then
      warn "ignoring invalid config line in $file: $raw_line"
      continue
    fi

    key="$(trim "${line%%=*}")"
    value="$(trim "${line#*=}")"
    value="$(strip_optional_quotes "$value")"

    case "$key" in
      AGENT_COLLAB_GUIDE)
        CONFIG_GUIDE="$value"
        ;;
      AGENT_COLLAB_REVIEW_DIR)
        CONFIG_REVIEW_DIR="$value"
        ;;
      AGENT_COLLAB_DEFAULT_CHALLENGER)
        CONFIG_DEFAULT_CHALLENGER="$value"
        ;;
      AGENT_COLLAB_TIMEOUT_SECONDS)
        CONFIG_TIMEOUT_SECONDS="$value"
        ;;
      AGENT_COLLAB_CLAUDE_TIMEOUT_SECONDS)
        CONFIG_CLAUDE_TIMEOUT_SECONDS="$value"
        ;;
      AGENT_COLLAB_CODEX_TIMEOUT_SECONDS)
        CONFIG_CODEX_TIMEOUT_SECONDS="$value"
        ;;
      AGENT_COLLAB_GEMINI_TIMEOUT_SECONDS)
        CONFIG_GEMINI_TIMEOUT_SECONDS="$value"
        ;;
      AGENT_COLLAB_CLAUDE_EFFORT)
        CONFIG_CLAUDE_EFFORT="$value"
        ;;
      AGENT_COLLAB_INBOX_DB)
        CONFIG_INBOX_DB="$value"
        ;;
      *)
        warn "ignoring unknown config key in $file: $key"
        ;;
    esac
  done < "$file"
}

absolute_existing_path() {
  local input="$1"
  local candidate="" dir base

  if [[ "$input" == /* ]]; then
    candidate="$input"
  elif [[ -e "$input" ]]; then
    candidate="$PWD/$input"
  elif [[ -e "$REPO_ROOT/$input" ]]; then
    candidate="$REPO_ROOT/$input"
  else
    err "path does not exist: $input"
  fi

  [[ -e "$candidate" ]] || err "path does not exist: $input"

  dir="$(cd "$(dirname "$candidate")" && pwd -P)"
  base="$(basename "$candidate")"
  printf '%s/%s\n' "$dir" "$base"
}

absolute_output_path() {
  local input="$1"
  local dir base

  if [[ "$input" == /* ]]; then
    dir="$(cd "$(dirname "$input")" && pwd -P)"
    base="$(basename "$input")"
    printf '%s/%s\n' "$dir" "$base"
    return
  fi

  printf '%s/%s\n' "$REPO_ROOT" "$input"
}

display_path() {
  local absolute_path="$1"

  if [[ "$absolute_path" == "$REPO_ROOT" ]]; then
    printf '.\n'
  elif [[ "$absolute_path" == "$REPO_ROOT/"* ]]; then
    printf '%s\n' "${absolute_path#$REPO_ROOT/}"
  else
    printf '%s\n' "$absolute_path"
  fi
}

validate_challenger() {
  case "$1" in
    claude|codex|gemini) ;;
    *)
      err "unsupported challenger: $1"
      ;;
  esac
}

validate_claude_effort() {
  case "$1" in
    low|medium|high|max) ;;
    *)
      err "unsupported Claude effort: $1"
      ;;
  esac
}

validate_timeout_seconds() {
  local value="$1"

  [[ "$value" =~ ^[0-9]+$ ]] || err "timeout must be a non-negative integer: $value"
}

path_already_selected() {
  local absolute_path="$1"
  local path

  if [[ -n "$GUIDE_PATH" && "$absolute_path" == "$GUIDE_PATH" ]]; then
    return 0
  fi

  if (( ${#SCOPE_PATHS[@]} > 0 )); then
    for path in "${SCOPE_PATHS[@]}"; do
      [[ "$path" == "$absolute_path" ]] && return 0
    done
  fi

  if (( ${#CONTEXT_PATHS[@]} > 0 )); then
    for path in "${CONTEXT_PATHS[@]}"; do
      [[ "$path" == "$absolute_path" ]] && return 0
    done
  fi

  return 1
}

prompt_needs_read_tool() {
  local inline_bytes_used=0
  local remaining_budget file_size include_bytes path

  if [[ -n "$GUIDE_PATH" ]]; then
    remaining_budget=$((INLINE_TOTAL_LIMIT_BYTES - inline_bytes_used))
    file_size="$(wc -c < "$GUIDE_PATH" | tr -d '[:space:]')"
    if (( remaining_budget <= 0 )); then
      return 0
    fi
    include_bytes=$INLINE_FILE_LIMIT_BYTES
    (( include_bytes > remaining_budget )) && include_bytes=$remaining_budget
    (( include_bytes > file_size )) && include_bytes=$file_size
    if (( file_size > include_bytes )); then
      return 0
    fi
    inline_bytes_used=$((inline_bytes_used + include_bytes))
  fi

  if (( ${#SCOPE_PATHS[@]} > 0 )); then
    for path in "${SCOPE_PATHS[@]}"; do
      remaining_budget=$((INLINE_TOTAL_LIMIT_BYTES - inline_bytes_used))
      file_size="$(wc -c < "$path" | tr -d '[:space:]')"
      if (( remaining_budget <= 0 )); then
        return 0
      fi
      include_bytes=$INLINE_FILE_LIMIT_BYTES
      (( include_bytes > remaining_budget )) && include_bytes=$remaining_budget
      (( include_bytes > file_size )) && include_bytes=$file_size
      if (( file_size > include_bytes )); then
        return 0
      fi
      inline_bytes_used=$((inline_bytes_used + include_bytes))
    done
  fi

  if (( ${#CONTEXT_PATHS[@]} > 0 )); then
    for path in "${CONTEXT_PATHS[@]}"; do
      remaining_budget=$((INLINE_TOTAL_LIMIT_BYTES - inline_bytes_used))
      file_size="$(wc -c < "$path" | tr -d '[:space:]')"
      if (( remaining_budget <= 0 )); then
        return 0
      fi
      include_bytes=$INLINE_FILE_LIMIT_BYTES
      (( include_bytes > remaining_budget )) && include_bytes=$remaining_budget
      (( include_bytes > file_size )) && include_bytes=$file_size
      if (( file_size > include_bytes )); then
        return 0
      fi
      inline_bytes_used=$((inline_bytes_used + include_bytes))
    done
  fi

  return 1
}

resolve_timeout_backend() {
  if (( TIMEOUT_SECONDS == 0 )); then
    TIMEOUT_BACKEND="disabled"
    TIMEOUT_COMMAND=""
    return
  fi

  if command -v timeout >/dev/null 2>&1; then
    TIMEOUT_BACKEND="timeout"
    TIMEOUT_COMMAND="$(command -v timeout)"
    return
  fi

  if command -v gtimeout >/dev/null 2>&1; then
    TIMEOUT_BACKEND="timeout"
    TIMEOUT_COMMAND="$(command -v gtimeout)"
    return
  fi

  if command -v python3 >/dev/null 2>&1; then
    TIMEOUT_BACKEND="python3"
    TIMEOUT_COMMAND="$(command -v python3)"
    return
  fi

  err "no timeout backend available; install timeout/gtimeout or python3, or set --timeout-seconds 0"
}

run_with_timeout() {
  local seconds="$1"
  shift
  local seconds_duration

  if (( seconds == 0 )); then
    "$@"
    return $?
  fi

  seconds_duration="${seconds}s"

  case "$TIMEOUT_BACKEND" in
    timeout)
      local stderr_output="" rc=0

      # Run the challenger directly so timeout's kill-after path keeps control
      # of the full subprocess instead of only an intermediate shell wrapper.
      exec 3>&1
      stderr_output="$("$TIMEOUT_COMMAND" -k 5s "$seconds_duration" "$@" 2>&1 1>&3)" || rc=$?
      exec 3>&-

      if [[ -n "$stderr_output" ]]; then
        printf '%s\n' "$stderr_output" >&2
      fi

      return "$rc"
      ;;
    python3)
      "$TIMEOUT_COMMAND" -c '
import os
import signal
import subprocess
import sys

timeout_seconds = int(sys.argv[1])
command = sys.argv[2:]
kwargs = {}
if hasattr(os, "setsid"):
    kwargs["start_new_session"] = True

proc = subprocess.Popen(command, **kwargs)
try:
    sys.exit(proc.wait(timeout=timeout_seconds))
except subprocess.TimeoutExpired:
    try:
        if hasattr(os, "killpg") and hasattr(os, "setsid"):
            os.killpg(proc.pid, signal.SIGTERM)
        else:
            proc.terminate()
    except ProcessLookupError:
        pass

    try:
        proc.wait(timeout=5)
    except subprocess.TimeoutExpired:
        try:
            if hasattr(os, "killpg") and hasattr(os, "setsid"):
                os.killpg(proc.pid, signal.SIGKILL)
            else:
                proc.kill()
        except ProcessLookupError:
            pass
        proc.wait()

    sys.exit(124)
' "$seconds" "$@"
      ;;
    *)
      err "timeout backend is not configured"
      ;;
  esac
}

is_timeout_status() {
  case "$1" in
    124|137) return 0 ;;
    *) return 1 ;;
  esac
}

prepare_review_file() {
  local timestamp out_dir temp_root
  timestamp="$(date +%Y%m%d-%H%M%S)"
  temp_root="${TMPDIR:-/tmp}"
  temp_root="${temp_root%/}"

  if [[ -n "$OUT_OVERRIDE" ]]; then
    REVIEW_FILE="$(absolute_output_path "$OUT_OVERRIDE")"
    if (( ! DRY_RUN )); then
      mkdir -p "$(dirname "$REVIEW_FILE")"
    fi
    return
  fi

  if [[ -n "$REVIEW_DIR" ]]; then
    out_dir="$(absolute_output_path "$REVIEW_DIR")"
    if (( ! DRY_RUN )); then
      mkdir -p "$out_dir"
    fi
    REVIEW_FILE="$out_dir/${timestamp}-${MODE}-${CHALLENGER}.md"
    return
  fi

  if (( DRY_RUN )); then
    REVIEW_FILE="$temp_root/agent-collab.${MODE}.${CHALLENGER}.${timestamp}.preview"
    return
  fi

  REVIEW_FILE="$(mktemp "$temp_root/agent-collab.${MODE}.${CHALLENGER}.XXXXXX")"
}

build_prompt() {
  local path absolute_path display inline_bytes_used remaining_budget file_size include_bytes

  inline_bytes_used=0

  if [[ "$MODE" == "challenge" ]]; then
    printf '%s\n' "Read the repo-local collaboration guide and relevant scope docs."
    printf '%s\n' "Reply in markdown only."
    printf '%s\n' "Do not modify files."
    printf '%s\n' "Focus on risks, regressions, simpler alternatives, and missing tests."
  else
    printf '%s\n' "Read the repo-local collaboration guide, scope docs, and resulting changes."
    printf '%s\n' "Reply in markdown only."
    printf '%s\n' "Do not modify files."
    printf '%s\n' "Focus on requirement mismatch, regressions, and missing verification."
  fi

  printf '\n'
  printf 'Repository root: %s\n' "$REPO_ROOT"

  if [[ -n "$GUIDE_DISPLAY" ]]; then
    printf 'Repo-local collaboration guide: %s\n' "$GUIDE_DISPLAY"
  fi

  if (( ${#SCOPE_DISPLAY[@]} > 0 )); then
    printf '%s\n' "Required scope paths:"
    for path in "${SCOPE_DISPLAY[@]}"; do
      printf -- '- %s\n' "$path"
    done
  fi

  if (( ${#CONTEXT_DISPLAY[@]} > 0 )); then
    printf '%s\n' "Additional context paths:"
    for path in "${CONTEXT_DISPLAY[@]}"; do
      printf -- '- %s\n' "$path"
    done
  fi

  if [[ -n "$EXTRA_PROMPT" ]]; then
    printf '\nAdditional instructions:\n%s\n' "$EXTRA_PROMPT"
  fi

  if [[ -n "$GUIDE_PATH" || ${#SCOPE_PATHS[@]} -gt 0 || ${#CONTEXT_PATHS[@]} -gt 0 ]]; then
    printf '\n'
    printf '%s\n' "Review the provided file contents directly."
    printf '%s\n' "Do not assume any additional repo context beyond the files included below."
    if (( CLAUDE_USE_READ_TOOL )); then
      printf '%s\n' "Some files below are truncated or omitted. Use the Read tool only if you need missing content."
    fi
  fi

  if [[ -n "$GUIDE_PATH" ]]; then
    remaining_budget=$((INLINE_TOTAL_LIMIT_BYTES - inline_bytes_used))
    file_size="$(wc -c < "$GUIDE_PATH" | tr -d '[:space:]')"
    if (( remaining_budget <= 0 )); then
      printf -- '\n----- BEGIN FILE: %s -----\n' "$GUIDE_DISPLAY"
      printf '[omitted: inline prompt size budget exhausted]\n'
      printf -- '----- END FILE: %s -----\n' "$GUIDE_DISPLAY"
    else
      include_bytes=$INLINE_FILE_LIMIT_BYTES
      (( include_bytes > remaining_budget )) && include_bytes=$remaining_budget
      (( include_bytes > file_size )) && include_bytes=$file_size
      printf -- '\n----- BEGIN FILE: %s -----\n' "$GUIDE_DISPLAY"
      if (( include_bytes > 0 )); then
        LC_ALL=C head -c "$include_bytes" "$GUIDE_PATH"
        printf '\n'
      fi
      if (( file_size > include_bytes )); then
        printf '\n[truncated: showing first %d of %d bytes]\n' "$include_bytes" "$file_size"
      fi
      printf -- '----- END FILE: %s -----\n' "$GUIDE_DISPLAY"
      inline_bytes_used=$((inline_bytes_used + include_bytes))
    fi
  fi

  if (( ${#SCOPE_PATHS[@]} > 0 )); then
    for path in "${!SCOPE_PATHS[@]}"; do
      absolute_path="${SCOPE_PATHS[$path]}"
      display="${SCOPE_DISPLAY[$path]}"
      remaining_budget=$((INLINE_TOTAL_LIMIT_BYTES - inline_bytes_used))
      file_size="$(wc -c < "$absolute_path" | tr -d '[:space:]')"
      if (( remaining_budget <= 0 )); then
        printf -- '\n----- BEGIN FILE: %s -----\n' "$display"
        printf '[omitted: inline prompt size budget exhausted]\n'
        printf -- '----- END FILE: %s -----\n' "$display"
        continue
      fi
      include_bytes=$INLINE_FILE_LIMIT_BYTES
      (( include_bytes > remaining_budget )) && include_bytes=$remaining_budget
      (( include_bytes > file_size )) && include_bytes=$file_size
      printf -- '\n----- BEGIN FILE: %s -----\n' "$display"
      if (( include_bytes > 0 )); then
        LC_ALL=C head -c "$include_bytes" "$absolute_path"
        printf '\n'
      fi
      if (( file_size > include_bytes )); then
        printf '\n[truncated: showing first %d of %d bytes]\n' "$include_bytes" "$file_size"
      fi
      printf -- '----- END FILE: %s -----\n' "$display"
      inline_bytes_used=$((inline_bytes_used + include_bytes))
    done
  fi

  if (( ${#CONTEXT_PATHS[@]} > 0 )); then
    for path in "${!CONTEXT_PATHS[@]}"; do
      absolute_path="${CONTEXT_PATHS[$path]}"
      display="${CONTEXT_DISPLAY[$path]}"
      remaining_budget=$((INLINE_TOTAL_LIMIT_BYTES - inline_bytes_used))
      file_size="$(wc -c < "$absolute_path" | tr -d '[:space:]')"
      if (( remaining_budget <= 0 )); then
        printf -- '\n----- BEGIN FILE: %s -----\n' "$display"
        printf '[omitted: inline prompt size budget exhausted]\n'
        printf -- '----- END FILE: %s -----\n' "$display"
        continue
      fi
      include_bytes=$INLINE_FILE_LIMIT_BYTES
      (( include_bytes > remaining_budget )) && include_bytes=$remaining_budget
      (( include_bytes > file_size )) && include_bytes=$file_size
      printf -- '\n----- BEGIN FILE: %s -----\n' "$display"
      if (( include_bytes > 0 )); then
        LC_ALL=C head -c "$include_bytes" "$absolute_path"
        printf '\n'
      fi
      if (( file_size > include_bytes )); then
        printf '\n[truncated: showing first %d of %d bytes]\n' "$include_bytes" "$file_size"
      fi
      printf -- '----- END FILE: %s -----\n' "$display"
      inline_bytes_used=$((inline_bytes_used + include_bytes))
    done
  fi
}

run_claude() {
  local output_file="$1"
  local claude_args=()
  command -v claude >/dev/null 2>&1 || err "claude CLI is not installed or not on PATH"

  claude_args=(claude -p --permission-mode plan --output-format text)
  if (( CLAUDE_USE_READ_TOOL )); then
    claude_args+=(--tools "Read")
  fi
  claude_args+=(--effort "$CLAUDE_EFFORT")

  (
    cd "$REPO_ROOT"
    # Only grant file reads when the inline prompt budget forced truncation or
    # omission. Fully inlined reviews stay faster and more tightly bounded.
    printf '%s' "$PROMPT" | run_with_timeout "$TIMEOUT_SECONDS" "${claude_args[@]}" > "$output_file"
  )
}

run_codex() {
  local output_file="$1"
  command -v codex >/dev/null 2>&1 || err "codex CLI is not installed or not on PATH"
  (
    cd "$REPO_ROOT"
    printf '%s' "$PROMPT" | run_with_timeout "$TIMEOUT_SECONDS" codex exec -C "$REPO_ROOT" -s read-only -o "$output_file" -
  )
}

run_gemini() {
  local output_file="$1"
  command -v gemini >/dev/null 2>&1 || err "gemini CLI is not installed or not on PATH"
  (
    cd "$REPO_ROOT"
    printf '%s' "$PROMPT" | run_with_timeout "$TIMEOUT_SECONDS" gemini -p "" --approval-mode plan -o text > "$output_file"
  )
}

review_file_has_content() {
  local path="$1"
  grep -q '[^[:space:]]' "$path"
}

run_review_command() {
  local challenger="$1"
  local temp_output temp_root status

  temp_root="${TMPDIR:-/tmp}"
  temp_root="${temp_root%/}"
  temp_output="$(mktemp "$temp_root/agent-collab.${MODE}.${challenger}.output.XXXXXX")"

  if "run_${challenger}" "$temp_output"; then
    :
  else
    status=$?
    rm -f "$temp_output"
    if is_timeout_status "$status"; then
      err "$challenger review timed out after ${TIMEOUT_SECONDS}s"
    fi
    err "$challenger review command failed with exit status $status"
  fi

  [[ -s "$temp_output" ]] || {
    rm -f "$temp_output"
    err "$challenger review command completed without usable output"
  }

  review_file_has_content "$temp_output" || {
    rm -f "$temp_output"
    err "$challenger review command completed with only whitespace output"
  }

  mv "$temp_output" "$REVIEW_FILE"
}

MODE="${1:-help}"
if [[ $# -gt 0 ]]; then
  shift
fi

resolve_peer_inbox_script() {
  if [[ -n "${AGENT_COLLAB_PEER_INBOX_DB_SCRIPT:-}" ]]; then
    printf '%s\n' "$AGENT_COLLAB_PEER_INBOX_DB_SCRIPT"
    return
  fi

  local self_dir
  self_dir="$(cd "$(dirname "$0")" && pwd -P)"
  if [[ -f "$self_dir/peer-inbox-db.py" ]]; then
    printf '%s\n' "$self_dir/peer-inbox-db.py"
    return
  fi

  if [[ -f "$HOME/.agent-collab/scripts/peer-inbox-db.py" ]]; then
    printf '%s\n' "$HOME/.agent-collab/scripts/peer-inbox-db.py"
    return
  fi

  err "peer-inbox-db.py not found (checked: AGENT_COLLAB_PEER_INBOX_DB_SCRIPT, $self_dir, ~/.agent-collab/scripts/)"
}

# resolve_peer_inbox_binary — returns the path to the Go peer-inbox
# binary if present, empty string otherwise. Same search shape as
# resolve_peer_web_binary. The Go binary is the default impl as of
# v3.4 Phase 5.1; set AGENT_COLLAB_IMPL=python to force the legacy
# Python script (bug-report reproducibility only — Python removal is
# tracked in Phase 6).
resolve_peer_inbox_binary() {
  if [[ -n "${AGENT_COLLAB_PEER_INBOX_BIN:-}" ]]; then
    if [[ -x "$AGENT_COLLAB_PEER_INBOX_BIN" ]]; then
      printf '%s\n' "$AGENT_COLLAB_PEER_INBOX_BIN"
    fi
    return
  fi
  local self_dir
  self_dir="$(cd "$(dirname "$0")" && pwd -P)"
  local repo_root
  repo_root="$(cd "$self_dir/.." && pwd -P 2>/dev/null || true)"
  if [[ -n "$repo_root" && -x "$repo_root/go/bin/peer-inbox" ]]; then
    printf '%s\n' "$repo_root/go/bin/peer-inbox"
    return
  fi
  if [[ -x "$HOME/.local/bin/peer-inbox" ]]; then
    printf '%s\n' "$HOME/.local/bin/peer-inbox"
    return
  fi
  local on_path
  on_path="$(command -v peer-inbox 2>/dev/null || true)"
  if [[ -n "$on_path" ]]; then
    printf '%s\n' "$on_path"
  fi
}

# resolve_peer_web_binary — returns the path to the Go peer-web binary
# if present, empty string otherwise. Search order matches the other
# Go binaries already dispatched from this script:
#   1. $AGENT_COLLAB_PEER_WEB_BIN (explicit override)
#   2. $repo/go/bin/peer-web (dev builds)
#   3. $HOME/.local/bin/peer-web (installed)
#   4. peer-web on PATH
resolve_peer_web_binary() {
  if [[ -n "${AGENT_COLLAB_PEER_WEB_BIN:-}" ]]; then
    if [[ -x "$AGENT_COLLAB_PEER_WEB_BIN" ]]; then
      printf '%s\n' "$AGENT_COLLAB_PEER_WEB_BIN"
    fi
    return
  fi
  local self_dir
  self_dir="$(cd "$(dirname "$0")" && pwd -P)"
  local repo_root
  repo_root="$(cd "$self_dir/.." && pwd -P 2>/dev/null || true)"
  if [[ -n "$repo_root" && -x "$repo_root/go/bin/peer-web" ]]; then
    printf '%s\n' "$repo_root/go/bin/peer-web"
    return
  fi
  if [[ -x "$HOME/.local/bin/peer-web" ]]; then
    printf '%s\n' "$HOME/.local/bin/peer-web"
    return
  fi
  local on_path
  on_path="$(command -v peer-web 2>/dev/null || true)"
  if [[ -n "$on_path" ]]; then
    printf '%s\n' "$on_path"
  fi
}

dispatch_peer_inbox() {
  local top_mode="$1"
  shift

  [[ $# -ge 1 ]] || err "missing subcommand for '$top_mode' (try: register, close, list, send, receive)"
  local sub="$1"
  shift

  # `peer web` routes to the Go binary when present — multi-room index
  # + no --pair-key lock + Python-free serving path (v3.2 frontend-go-
  # rewrite). Falls back to Python if the binary isn't built, or if
  # AGENT_COLLAB_WEB_IMPL=python forces the fallback for bug-report
  # reproducibility.
  if [[ "$top_mode" == "peer" && "$sub" == "web" ]]; then
    if [[ "${AGENT_COLLAB_WEB_IMPL:-}" != "python" ]]; then
      local peer_web_bin
      peer_web_bin="$(resolve_peer_web_binary)"
      if [[ -n "$peer_web_bin" ]]; then
        REPO_ROOT="$(detect_repo_root)"
        load_config "$REPO_ROOT/.agent-collab.env"
        if [[ -n "$CONFIG_INBOX_DB" && -z "${AGENT_COLLAB_INBOX_DB:-}" ]]; then
          export AGENT_COLLAB_INBOX_DB="$CONFIG_INBOX_DB"
        fi
        exec "$peer_web_bin" "$@"
      fi
    fi
  fi

  # v3.4 Phase 5.1: Go is the default impl for all non-`peer web` verbs.
  # Every verb has byte-equivalent parity coverage (52 fixtures +
  # federation-smoke + peer-web-go-parity). Set AGENT_COLLAB_IMPL=python
  # to route back to the legacy script for bug-report reproducibility.
  # Fresh checkouts that haven't run `go build` fall through to Python
  # rather than hard-fail.
  if [[ "${AGENT_COLLAB_IMPL:-}" != "python" ]]; then
    local peer_inbox_bin
    peer_inbox_bin="$(resolve_peer_inbox_binary)"
    if [[ -n "$peer_inbox_bin" ]]; then
      REPO_ROOT="$(detect_repo_root)"
      load_config "$REPO_ROOT/.agent-collab.env"
      if [[ -n "$CONFIG_INBOX_DB" && -z "${AGENT_COLLAB_INBOX_DB:-}" ]]; then
        export AGENT_COLLAB_INBOX_DB="$CONFIG_INBOX_DB"
      fi
      exec "$peer_inbox_bin" "${top_mode}-${sub}" "$@"
    fi
    # Binary missing — fall through to Python rather than hard-fail so
    # fresh checkouts still work before `go build`.
  fi

  local python_cmd
  if command -v python3 >/dev/null 2>&1; then
    python_cmd="python3"
  else
    err "python3 not on PATH; peer-inbox requires python3"
  fi

  local script
  script="$(resolve_peer_inbox_script)"

  # Load repo-local config so AGENT_COLLAB_INBOX_DB flows through, but
  # prefer caller's existing env var (explicit wins over file).
  REPO_ROOT="$(detect_repo_root)"
  load_config "$REPO_ROOT/.agent-collab.env"
  if [[ -n "$CONFIG_INBOX_DB" && -z "${AGENT_COLLAB_INBOX_DB:-}" ]]; then
    export AGENT_COLLAB_INBOX_DB="$CONFIG_INBOX_DB"
  fi

  exec "$python_cmd" "$script" "${top_mode}-${sub}" "$@"
}

case "$MODE" in
  help|-h|--help)
    usage
    exit 0
    ;;
  challenge|verify) ;;
  session|peer|hook|room)
    dispatch_peer_inbox "$MODE" "$@"
    ;;
  *)
    err "unknown subcommand: $MODE"
    ;;
esac

while [[ $# -gt 0 ]]; do
  case "$1" in
    --challenger)
      [[ $# -ge 2 ]] || err "--challenger requires a value"
      CHALLENGER="$2"
      shift 2
      ;;
    --scope)
      [[ $# -ge 2 ]] || err "--scope requires a value"
      SCOPE_INPUTS+=("$2")
      shift 2
      ;;
    --context)
      [[ $# -ge 2 ]] || err "--context requires a value"
      CONTEXT_INPUTS+=("$2")
      shift 2
      ;;
    --guide)
      [[ $# -ge 2 ]] || err "--guide requires a value"
      GUIDE_OVERRIDE="$2"
      shift 2
      ;;
    --review-dir)
      [[ $# -ge 2 ]] || err "--review-dir requires a value"
      REVIEW_DIR_OVERRIDE="$2"
      shift 2
      ;;
    --out)
      [[ $# -ge 2 ]] || err "--out requires a value"
      OUT_OVERRIDE="$2"
      shift 2
      ;;
    --prompt)
      [[ $# -ge 2 ]] || err "--prompt requires a value"
      EXTRA_PROMPT="$2"
      shift 2
      ;;
    --timeout-seconds)
      [[ $# -ge 2 ]] || err "--timeout-seconds requires a value"
      TIMEOUT_OVERRIDE="$2"
      shift 2
      ;;
    --dry-run)
      DRY_RUN=1
      shift
      ;;
    -h|--help)
      usage
      exit 0
      ;;
    *)
      err "unknown argument: $1"
      ;;
  esac
done

REPO_ROOT="$(detect_repo_root)"
load_config "$REPO_ROOT/.agent-collab.env"

if [[ -n "$GUIDE_OVERRIDE" ]]; then
  GUIDE_PATH="$(absolute_existing_path "$GUIDE_OVERRIDE")"
elif [[ -n "$CONFIG_GUIDE" ]]; then
  GUIDE_PATH="$(absolute_existing_path "$CONFIG_GUIDE")"
elif [[ -f "$REPO_ROOT/AGENT-COLLABORATION.md" ]]; then
  GUIDE_PATH="$(absolute_existing_path "$REPO_ROOT/AGENT-COLLABORATION.md")"
fi

if [[ -n "$GUIDE_PATH" ]]; then
  GUIDE_DISPLAY="$(display_path "$GUIDE_PATH")"
fi

if [[ -n "$REVIEW_DIR_OVERRIDE" ]]; then
  REVIEW_DIR="$REVIEW_DIR_OVERRIDE"
elif [[ -n "$CONFIG_REVIEW_DIR" ]]; then
  REVIEW_DIR="$CONFIG_REVIEW_DIR"
fi

if [[ -z "$CHALLENGER" ]]; then
  CHALLENGER="$CONFIG_DEFAULT_CHALLENGER"
fi

[[ -n "$CHALLENGER" ]] || err "set --challenger or AGENT_COLLAB_DEFAULT_CHALLENGER in .agent-collab.env"
validate_challenger "$CHALLENGER"

if [[ -n "$CONFIG_CLAUDE_EFFORT" ]]; then
  CLAUDE_EFFORT="$CONFIG_CLAUDE_EFFORT"
fi
validate_claude_effort "$CLAUDE_EFFORT"

if [[ -n "$TIMEOUT_OVERRIDE" ]]; then
  TIMEOUT_SECONDS="$TIMEOUT_OVERRIDE"
elif [[ "$CHALLENGER" == "claude" && -n "$CONFIG_CLAUDE_TIMEOUT_SECONDS" ]]; then
  TIMEOUT_SECONDS="$CONFIG_CLAUDE_TIMEOUT_SECONDS"
elif [[ "$CHALLENGER" == "codex" && -n "$CONFIG_CODEX_TIMEOUT_SECONDS" ]]; then
  TIMEOUT_SECONDS="$CONFIG_CODEX_TIMEOUT_SECONDS"
elif [[ "$CHALLENGER" == "gemini" && -n "$CONFIG_GEMINI_TIMEOUT_SECONDS" ]]; then
  TIMEOUT_SECONDS="$CONFIG_GEMINI_TIMEOUT_SECONDS"
elif [[ -n "$CONFIG_TIMEOUT_SECONDS" ]]; then
  TIMEOUT_SECONDS="$CONFIG_TIMEOUT_SECONDS"
fi
validate_timeout_seconds "$TIMEOUT_SECONDS"
resolve_timeout_backend
if (( TIMEOUT_SECONDS == 0 )); then
  warn "timeouts are disabled for $CHALLENGER review"
fi

if (( ${#SCOPE_INPUTS[@]} == 0 && ${#CONTEXT_INPUTS[@]} == 0 )) && [[ -z "$EXTRA_PROMPT" ]]; then
  err "provide at least one --scope, --context, or --prompt value"
fi

if (( ${#SCOPE_INPUTS[@]} > 0 )); then
  for path in "${SCOPE_INPUTS[@]}"; do
    absolute_path="$(absolute_existing_path "$path")"
    if path_already_selected "$absolute_path"; then
      continue
    fi
    SCOPE_PATHS+=("$absolute_path")
    SCOPE_DISPLAY+=("$(display_path "$absolute_path")")
  done
fi

if (( ${#CONTEXT_INPUTS[@]} > 0 )); then
  for path in "${CONTEXT_INPUTS[@]}"; do
    absolute_path="$(absolute_existing_path "$path")"
    if path_already_selected "$absolute_path"; then
      continue
    fi
    CONTEXT_PATHS+=("$absolute_path")
    CONTEXT_DISPLAY+=("$(display_path "$absolute_path")")
  done
fi

prepare_review_file
if [[ "$CHALLENGER" == "claude" ]] && prompt_needs_read_tool; then
  CLAUDE_USE_READ_TOOL=1
fi
PROMPT="$(build_prompt)"

if (( DRY_RUN )); then
  cat <<EOF
mode: $MODE
challenger: $CHALLENGER
repo_root: $REPO_ROOT
config: ${CONFIG_FILE:-none}
review_file: $REVIEW_FILE
timeout_seconds: $TIMEOUT_SECONDS
timeout_backend: $TIMEOUT_BACKEND

prompt:
$PROMPT
EOF
  exit 0
fi

run_review_command "$CHALLENGER"

printf 'review: %s\n' "$REVIEW_FILE"
