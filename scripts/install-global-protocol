#!/usr/bin/env bash
set -euo pipefail

PROJECT_ROOT="$(cd "$(dirname "$0")/.." && pwd)"
CLAUDE_TARGET="$HOME/.claude/CLAUDE.md"
CODEX_TARGET="$HOME/.codex/AGENTS.md"
GEMINI_TARGET="$HOME/.gemini/GEMINI.md"
BIN_DIR="${AGENT_COLLAB_BIN_DIR:-$HOME/.local/bin}"
COMMAND_TARGET="$BIN_DIR/agent-collab"
TIMESTAMP="$(date +%Y%m%d-%H%M%S)-$$"
START_MARKER="<!-- BEGIN agent-collaboration -->"
END_MARKER="<!-- END agent-collaboration -->"

PEER_INBOX_HOME="$HOME/.agent-collab"
PEER_INBOX_SCRIPTS_DIR="$PEER_INBOX_HOME/scripts"
PEER_INBOX_HOOKS_DIR="$PEER_INBOX_HOME/hooks"
PEER_INBOX_DB_SCRIPT="$PEER_INBOX_SCRIPTS_DIR/peer-inbox-db.py"
PEER_INBOX_CHANNEL_SCRIPT="$PEER_INBOX_SCRIPTS_DIR/peer-inbox-channel.py"
PEER_INBOX_HOOK_SCRIPT="$PEER_INBOX_HOOKS_DIR/peer-inbox-inject.sh"
# Topic 3 v0 (auto-reply daemon) — go binaries + config dir.
PEER_INBOX_DAEMONS_DIR="$PEER_INBOX_HOME/daemons"
PEER_INBOX_DAEMON_BIN="$BIN_DIR/agent-collab-daemon"
PEER_INBOX_GO_CLI="$BIN_DIR/peer-inbox"
PEER_INBOX_DAEMON_EXAMPLE_CFG="$PEER_INBOX_DAEMONS_DIR/example.json.disabled"
CLAUDE_SETTINGS="$HOME/.claude/settings.json"
CLAUDE_COMMANDS_DIR="$HOME/.claude/commands"
CLAUDE_SKILLS_DIR="$HOME/.claude/skills"
CODEX_HOOKS="$HOME/.codex/hooks.json"
CODEX_CONFIG="$HOME/.codex/config.toml"
GEMINI_SETTINGS="$HOME/.gemini/settings.json"
SLASH_COMMANDS=("agent-collab.md" "peer.md")
SKILLS=("install-agent-collab")

MODE="${1:-install}"

err() {
  echo "error: $*" >&2
  exit 1
}

render_template() {
  local src="$1"
  [[ -s "$src" ]] || err "missing or empty template: $src"
  sed "s|{{PROJECT_ROOT}}|$PROJECT_ROOT|g" "$src"
}

render_block() {
  local src="$1"
  printf '%s\n' "$START_MARKER"
  render_template "$src"
  printf '\n%s\n' "$END_MARKER"
}

first_nonempty_line() {
  local path="$1"
  awk 'NF { print; exit }' "$path"
}

looks_like_legacy_install() {
  local target="$1"
  local expected_header="$2"

  [[ -f "$target" ]] || return 1
  grep -Fq "$START_MARKER" "$target" && return 1
  [[ "$(first_nonempty_line "$target")" == "$expected_header" ]]
}

write_installed_file() {
  local target="$1"
  local block_file="$2"
  local rendered_template="$3"
  local expected_header="$4"
  local next_file

  next_file="$(mktemp)"

  if [[ ! -f "$target" || ! -s "$target" ]]; then
    cp "$block_file" "$next_file"
  elif looks_like_legacy_install "$target" "$expected_header"; then
    cp "$block_file" "$next_file"
  elif grep -Fq "$START_MARKER" "$target"; then
    awk -v start="$START_MARKER" -v end="$END_MARKER" -v block="$block_file" '
      BEGIN {
        while ((getline line < block) > 0) {
          replacement = replacement line ORS
        }
        close(block)
      }
      $0 == start {
        if (!replaced) {
          printf "%s", replacement
          replaced = 1
        }
        in_block = 1
        next
      }
      $0 == end {
        in_block = 0
        next
      }
      !in_block { print }
      END {
        if (!replaced) {
          if (NR > 0) print ""
          printf "%s", replacement
        }
      }
    ' "$target" > "$next_file"
  elif cmp -s "$target" "$rendered_template"; then
    cp "$block_file" "$next_file"
  else
    cp "$target" "$next_file"
    printf '\n\n' >> "$next_file"
    cat "$block_file" >> "$next_file"
  fi

  if [[ -f "$target" ]] && cmp -s "$target" "$next_file"; then
    echo "current: $target"
    rm -f "$next_file"
    return
  fi

  if [[ -f "$target" ]]; then
    cp "$target" "${target}.bak.${TIMESTAMP}"
    echo "backup: ${target}.bak.${TIMESTAMP}"
  fi

  mv "$next_file" "$target"
  echo "installed: $target"
}

remove_installed_block() {
  local target="$1"
  local next_file

  if [[ ! -f "$target" ]]; then
    echo "missing: $target"
    return
  fi

  next_file="$(mktemp)"

  if grep -Fq "$START_MARKER" "$target"; then
    awk -v start="$START_MARKER" -v end="$END_MARKER" '
      $0 == start { in_block = 1; next }
      $0 == end { in_block = 0; next }
      !in_block { print }
    ' "$target" > "$next_file"
  else
    echo "no managed block: $target"
    rm -f "$next_file"
    return
  fi

  if [[ -f "$target" ]] && cmp -s "$target" "$next_file"; then
    echo "current: $target"
    rm -f "$next_file"
    return
  fi

  cp "$target" "${target}.bak.${TIMESTAMP}"
  echo "backup: ${target}.bak.${TIMESTAMP}"

  if [[ -s "$next_file" ]]; then
    mv "$next_file" "$target"
    echo "uninstalled: $target"
  else
    rm -f "$next_file" "$target"
    echo "removed empty file: $target"
  fi
}

write_command_file() {
  local target="$1"
  local source="$2"
  local next_file

  [[ -s "$source" ]] || err "missing or empty command source: $source"

  next_file="$(mktemp)"
  cp "$source" "$next_file"
  chmod +x "$next_file"

  if [[ -f "$target" ]] && cmp -s "$target" "$next_file"; then
    echo "current: $target"
    rm -f "$next_file"
    return
  fi

  mkdir -p "$(dirname "$target")"

  if [[ -f "$target" ]]; then
    cp "$target" "${target}.bak.${TIMESTAMP}"
    echo "backup: ${target}.bak.${TIMESTAMP}"
  fi

  mv "$next_file" "$target"
  chmod +x "$target"
  echo "installed: $target"
}

remove_managed_command() {
  local target="$1"

  if [[ ! -f "$target" ]]; then
    echo "missing: $target"
    return
  fi

  if ! grep -Fq "# agent-collaboration managed command" "$target"; then
    echo "no managed command: $target"
    return
  fi

  cp "$target" "${target}.bak.${TIMESTAMP}"
  echo "backup: ${target}.bak.${TIMESTAMP}"
  rm -f "$target"
  echo "uninstalled: $target"
}

install_peer_inbox_file() {
  local source="$1"
  local target="$2"
  local target_dir

  [[ -s "$source" ]] || err "missing or empty source: $source"

  target_dir="$(dirname "$target")"
  mkdir -p "$target_dir"

  if [[ -f "$target" ]] && cmp -s "$source" "$target"; then
    echo "current: $target"
    return
  fi

  if [[ -f "$target" ]]; then
    cp "$target" "${target}.bak.${TIMESTAMP}"
    echo "backup: ${target}.bak.${TIMESTAMP}"
  fi

  cp "$source" "$target"
  chmod +x "$target"
  echo "installed: $target"
}

remove_peer_inbox_file() {
  local target="$1"

  if [[ ! -f "$target" ]]; then
    echo "missing: $target"
    return
  fi

  cp "$target" "${target}.bak.${TIMESTAMP}"
  echo "backup: ${target}.bak.${TIMESTAMP}"
  rm -f "$target"
  echo "uninstalled: $target"
}

# Topic 3 v0 (auto-reply daemon) install helpers.
#
# Two Go binaries get installed to $BIN_DIR so the daemon + its spawned
# agents can invoke them from PATH:
#
#   agent-collab-daemon  — the daemon itself; operators run this per
#                          managed label.
#   peer-inbox           — Go CLI exposing daemon-claim / daemon-complete
#                          / daemon-sweep verbs (from commit 4). Spawned
#                          CLIs call `peer-inbox daemon-complete ...`
#                          as their final action per §7.2 mechanism (1).
#
# The daemon config dir (~/.agent-collab/daemons/) gets created with a
# disabled example config file that operators copy + edit to set up a
# managed daemon. Extension .json.disabled ensures the example doesn't
# accidentally get auto-loaded by anything that enumerates the dir.
#
# Sweeper timer (systemd-user-timer on Linux / launchd plist on macOS /
# cron on everything) is intentionally NOT auto-installed — installing
# a system-scoped timer without operator opt-in crosses the "shared
# system state" line the global protocol's tone-and-style guidance
# warns about. Operator guide at docs/DAEMON-OPERATOR-GUIDE.md covers
# manual setup for each platform.

install_go_binary() {
  # install_go_binary <target-path> <go-pkg-path> <descriptor>
  local target="$1"
  local pkg="$2"
  local descriptor="$3"

  if ! command -v go >/dev/null 2>&1; then
    echo "skip: $descriptor — go toolchain not on PATH (install go to enable daemon-mode)"
    return
  fi

  mkdir -p "$(dirname "$target")"
  local tmp="${target}.new.${TIMESTAMP}"

  # Build into a sibling tmp file, then atomically swap. Avoids clobbering
  # a running daemon's binary mid-install (rename is atomic on same FS;
  # a running process keeps its own inode).
  if ! ( cd "$PROJECT_ROOT/go" && go build -o "$tmp" "./cmd/$pkg" ) 2>&1; then
    rm -f "$tmp"
    err "$descriptor build failed (./cmd/$pkg)"
  fi

  if [[ -f "$target" ]] && cmp -s "$tmp" "$target"; then
    rm -f "$tmp"
    echo "current: $target"
    return
  fi

  if [[ -f "$target" ]]; then
    cp "$target" "${target}.bak.${TIMESTAMP}"
    echo "backup: ${target}.bak.${TIMESTAMP}"
  fi

  mv "$tmp" "$target"
  chmod +x "$target"
  echo "installed: $target"
}

remove_go_binary() {
  local target="$1"

  if [[ ! -f "$target" ]]; then
    echo "missing: $target"
    return
  fi

  cp "$target" "${target}.bak.${TIMESTAMP}"
  echo "backup: ${target}.bak.${TIMESTAMP}"
  rm -f "$target"
  echo "uninstalled: $target"
}

install_daemon_config_dir() {
  # Create the per-label daemon config dir + a disabled example operators
  # can copy as a starting template.
  mkdir -p "$PEER_INBOX_DAEMONS_DIR"

  if [[ -f "$PEER_INBOX_DAEMON_EXAMPLE_CFG" ]]; then
    echo "current: $PEER_INBOX_DAEMON_EXAMPLE_CFG"
    return
  fi

  cat >"$PEER_INBOX_DAEMON_EXAMPLE_CFG" <<'EOF'
{
  "_note": "Topic 3 daemon config template. Copy to <label>.json and edit. Invoke via: agent-collab-daemon --config <label>",

  "label": "CHANGEME-reviewer-codex",
  "cwd":   "CHANGEME-/absolute/path/to/workspace",
  "session_key": "CHANGEME-stable-session-key-string",
  "cli": "codex",

  "ack_timeout":   300,
  "sweep_ttl":     600,
  "poll_interval": 2,
  "pause_on_idle": 1800,

  "claude_settings": "",
  "log_path": "",

  "_arch_d_note": "Topic 3 v0.1 (Arch D) opt-in: set cli_session_resume=true to pass the CLI vendor's native session-ID into subsequent spawns (codex+gemini only; no-op + warn for claude). Default false preserves Topic 3 v0 fresh-invocation. See docs/DAEMON-OPERATOR-GUIDE.md Arch D section.",
  "cli_session_resume": false
}
EOF
  chmod 0644 "$PEER_INBOX_DAEMON_EXAMPLE_CFG"
  echo "installed: $PEER_INBOX_DAEMON_EXAMPLE_CFG"
}

remove_daemon_config_dir() {
  # Intentional: never remove operator-authored .json configs or the
  # daemons/ dir if it contains anything other than the example. Only
  # remove the example template + empty dir.
  if [[ -f "$PEER_INBOX_DAEMON_EXAMPLE_CFG" ]]; then
    rm -f "$PEER_INBOX_DAEMON_EXAMPLE_CFG"
    echo "uninstalled: $PEER_INBOX_DAEMON_EXAMPLE_CFG"
  fi
  if [[ -d "$PEER_INBOX_DAEMONS_DIR" ]]; then
    # rmdir fails non-empty; that's exactly the guard we want.
    rmdir "$PEER_INBOX_DAEMONS_DIR" 2>/dev/null \
      && echo "removed empty dir: $PEER_INBOX_DAEMONS_DIR" \
      || echo "kept (non-empty): $PEER_INBOX_DAEMONS_DIR"
  fi
}

install_slash_command() {
  local source="$1"
  local target="$2"

  [[ -s "$source" ]] || err "missing or empty slash command: $source"

  mkdir -p "$(dirname "$target")"

  if [[ -f "$target" ]] && cmp -s "$source" "$target"; then
    echo "current: $target"
    return
  fi

  if [[ -f "$target" ]]; then
    cp "$target" "${target}.bak.${TIMESTAMP}"
    echo "backup: ${target}.bak.${TIMESTAMP}"
  fi

  cp "$source" "$target"
  echo "installed: $target"
}

remove_slash_command() {
  local target="$1"

  if [[ ! -f "$target" ]]; then
    echo "missing: $target"
    return
  fi

  cp "$target" "${target}.bak.${TIMESTAMP}"
  echo "backup: ${target}.bak.${TIMESTAMP}"
  rm -f "$target"
  echo "uninstalled: $target"
}

install_skill_dir() {
  local source_dir="$1"
  local target_dir="$2"
  local skill_file="$source_dir/SKILL.md"

  [[ -s "$skill_file" ]] || err "missing SKILL.md in $source_dir"

  mkdir -p "$target_dir"

  if [[ -f "$target_dir/SKILL.md" ]] && cmp -s "$skill_file" "$target_dir/SKILL.md"; then
    echo "current: $target_dir/SKILL.md"
    return
  fi

  if [[ -f "$target_dir/SKILL.md" ]]; then
    cp "$target_dir/SKILL.md" "$target_dir/SKILL.md.bak.${TIMESTAMP}"
    echo "backup: $target_dir/SKILL.md.bak.${TIMESTAMP}"
  fi

  cp "$skill_file" "$target_dir/SKILL.md"
  echo "installed: $target_dir/SKILL.md"
}

remove_skill_dir() {
  local target_dir="$1"
  local skill_file="$target_dir/SKILL.md"

  if [[ ! -f "$skill_file" ]]; then
    echo "missing: $skill_file"
    return
  fi

  cp "$skill_file" "$skill_file.bak.${TIMESTAMP}"
  echo "backup: $skill_file.bak.${TIMESTAMP}"
  rm -f "$skill_file"
  # Remove the directory only if it is empty after the skill file is gone.
  rmdir "$target_dir" 2>/dev/null || true
  echo "uninstalled: $skill_file"
}

merge_user_mcp_server() {
  # Ensure ~/.claude.json has a user-level mcpServers.peer-inbox entry so
  # that `claude --dangerously-load-development-channels server:peer-inbox`
  # resolves in any cwd, not only repos that happen to declare it locally.
  local channel_script="$1"
  local claude_config="$HOME/.claude.json"
  local timestamp="$2"

  CHANNEL_SCRIPT="$channel_script" CLAUDE_CONFIG="$claude_config" TS="$timestamp" python3 <<'PY'
import json
import os
import shutil
from pathlib import Path

config_path = Path(os.environ["CLAUDE_CONFIG"])
channel = os.environ["CHANNEL_SCRIPT"]

if config_path.exists() and config_path.stat().st_size > 0:
    data = json.loads(config_path.read_text())
else:
    data = {}

if not isinstance(data, dict):
    print(f"error: {config_path} root is not a JSON object")
    raise SystemExit(1)

servers = data.setdefault("mcpServers", {})
if not isinstance(servers, dict):
    print(f"error: {config_path}:mcpServers is not an object")
    raise SystemExit(1)

desired = {"command": "python3", "args": [channel]}
if servers.get("peer-inbox") == desired:
    print(f"current: {config_path} (peer-inbox mcpServers)")
    raise SystemExit(0)

if config_path.exists():
    shutil.copy2(config_path, f"{config_path}.bak.{os.environ['TS']}")

servers["peer-inbox"] = desired
data["mcpServers"] = servers
config_path.write_text(json.dumps(data, indent=2) + "\n")
print(f"installed: {config_path} (peer-inbox mcpServers)")
PY
}

remove_user_mcp_server() {
  local claude_config="$HOME/.claude.json"
  local timestamp="$1"

  CLAUDE_CONFIG="$claude_config" TS="$timestamp" python3 <<'PY'
import json
import os
import shutil
from pathlib import Path

config_path = Path(os.environ["CLAUDE_CONFIG"])
if not config_path.exists():
    print(f"missing: {config_path}")
    raise SystemExit(0)

data = json.loads(config_path.read_text())
servers = data.get("mcpServers") or {}
if "peer-inbox" not in servers:
    print(f"no managed entry: {config_path} (peer-inbox mcpServers)")
    raise SystemExit(0)

shutil.copy2(config_path, f"{config_path}.bak.{os.environ['TS']}")
del servers["peer-inbox"]
if not servers:
    data.pop("mcpServers", None)
config_path.write_text(json.dumps(data, indent=2) + "\n")
print(f"uninstalled: {config_path} (peer-inbox mcpServers)")
PY
}

merge_claude_hook() {
  local settings="$1"
  local hook_command="$2"
  local timestamp="$3"

  mkdir -p "$(dirname "$settings")"

  if [[ -f "$settings" ]]; then
    cp "$settings" "${settings}.bak.${timestamp}"
  fi

  HOOK_COMMAND="$hook_command" SETTINGS_PATH="$settings" python3 <<'PY'
import json
import os
import sys
from pathlib import Path

settings_path = Path(os.environ["SETTINGS_PATH"])
hook_command = os.environ["HOOK_COMMAND"]

if settings_path.exists() and settings_path.stat().st_size > 0:
    try:
        data = json.loads(settings_path.read_text())
    except json.JSONDecodeError as e:
        print(f"error: {settings_path} is not valid JSON: {e}", file=sys.stderr)
        sys.exit(1)
    if not isinstance(data, dict):
        print(f"error: {settings_path} root is not a JSON object", file=sys.stderr)
        sys.exit(1)
else:
    data = {}

hooks = data.setdefault("hooks", {})
if not isinstance(hooks, dict):
    print("error: settings.hooks is not an object", file=sys.stderr)
    sys.exit(1)

ups = hooks.setdefault("UserPromptSubmit", [])
if not isinstance(ups, list):
    print("error: settings.hooks.UserPromptSubmit is not a list", file=sys.stderr)
    sys.exit(1)

def matcher_has_our_command(matcher):
    if not isinstance(matcher, dict):
        return False
    for h in matcher.get("hooks", []) or []:
        if isinstance(h, dict) and "peer-inbox-inject.sh" in (h.get("command") or ""):
            return True
    return False

our_block = {
    "hooks": [
        {"type": "command", "command": hook_command, "timeout": 5}
    ]
}

# Surgical install: if any matcher already references our command, leave
# it unchanged (respect user customizations such as adjusted timeout or a
# matcher field). Only append a fresh block if no matcher references us.
already_installed = any(matcher_has_our_command(m) for m in ups)
changed = False
if already_installed:
    pass
else:
    ups.append(our_block)
    changed = True

hooks["UserPromptSubmit"] = ups

if not changed:
    print(f"current: {settings_path}")
else:
    settings_path.write_text(json.dumps(data, indent=2) + "\n")
    print(f"installed: {settings_path} (UserPromptSubmit hook)")
PY
}

remove_claude_hook() {
  local settings="$1"
  local timestamp="$2"

  if [[ ! -f "$settings" ]]; then
    echo "missing: $settings"
    return
  fi

  cp "$settings" "${settings}.bak.${timestamp}"

  SETTINGS_PATH="$settings" python3 <<'PY'
import json
import os
import sys
from pathlib import Path

settings_path = Path(os.environ["SETTINGS_PATH"])
try:
    data = json.loads(settings_path.read_text())
except json.JSONDecodeError as e:
    print(f"error: {settings_path} is not valid JSON: {e}", file=sys.stderr)
    sys.exit(1)

hooks = data.get("hooks") or {}
ups = hooks.get("UserPromptSubmit") or []
if not isinstance(ups, list):
    print(f"warn: UserPromptSubmit is not a list; skipping")
    sys.exit(0)

def is_our_hook(h):
    return isinstance(h, dict) and "peer-inbox-inject.sh" in (h.get("command") or "")

touched = False
new_ups = []
for matcher in ups:
    if not isinstance(matcher, dict):
        new_ups.append(matcher)
        continue
    inner = matcher.get("hooks") or []
    if not isinstance(inner, list):
        new_ups.append(matcher)
        continue
    kept_inner = [h for h in inner if not is_our_hook(h)]
    if len(kept_inner) == len(inner):
        new_ups.append(matcher)
        continue
    touched = True
    # Only our hook in this matcher — drop the whole matcher block so we
    # don't leave a stub behind. Otherwise keep the matcher with sibling
    # hooks intact.
    if kept_inner:
        new_matcher = dict(matcher)
        new_matcher["hooks"] = kept_inner
        new_ups.append(new_matcher)

if not touched:
    print(f"no managed block: {settings_path}")
    sys.exit(0)

if new_ups:
    hooks["UserPromptSubmit"] = new_ups
else:
    hooks.pop("UserPromptSubmit", None)
    if not hooks:
        data.pop("hooks", None)

settings_path.write_text(json.dumps(data, indent=2) + "\n")
print(f"uninstalled: {settings_path} (UserPromptSubmit hook)")
PY
}

# merge_hook_json is the generic installer for a JSON-based hook config.
# Claude (settings.json), Codex (hooks.json), and Gemini (settings.json)
# all expose the same hooks.<event>[].hooks[] array-of-command shape;
# only the file path, event-name key, and timeout UNIT differ. One
# implementation reduces the B1/B8 drift class gamma/alpha flagged in
# Track B.
#
# Timeout-unit caveat (found via probe-J empirical run 2026-04-18):
# Claude's timeout is seconds (default 60s); Codex's timeout is seconds
# (default 600s); Gemini's timeout is MILLISECONDS (default 60000ms).
# Caller passes the raw value in the invoking CLI's native unit. Our
# hook runs ~5-10ms on a warm box and up to a few hundred ms cold; 5s /
# 5000ms is a safe ceiling that all three tolerate.
#
# Usage: merge_hook_json <settings_path> <event_name> <hook_command> <timeout> <timestamp>
merge_hook_json() {
  local settings="$1"
  local event_name="$2"
  local hook_command="$3"
  local timeout="$4"
  local timestamp="$5"

  mkdir -p "$(dirname "$settings")"

  if [[ -f "$settings" ]]; then
    cp "$settings" "${settings}.bak.${timestamp}"
  fi

  HOOK_COMMAND="$hook_command" SETTINGS_PATH="$settings" EVENT_NAME="$event_name" HOOK_TIMEOUT="$timeout" python3 <<'PY'
import json
import os
import sys
from pathlib import Path

settings_path = Path(os.environ["SETTINGS_PATH"])
hook_command = os.environ["HOOK_COMMAND"]
event_name = os.environ["EVENT_NAME"]
hook_timeout = int(os.environ["HOOK_TIMEOUT"])

if settings_path.exists() and settings_path.stat().st_size > 0:
    try:
        data = json.loads(settings_path.read_text())
    except json.JSONDecodeError as e:
        print(f"error: {settings_path} is not valid JSON: {e}", file=sys.stderr)
        sys.exit(1)
    if not isinstance(data, dict):
        print(f"error: {settings_path} root is not a JSON object", file=sys.stderr)
        sys.exit(1)
else:
    data = {}

hooks = data.setdefault("hooks", {})
if not isinstance(hooks, dict):
    print(f"error: {settings_path} hooks is not an object", file=sys.stderr)
    sys.exit(1)

entries = hooks.setdefault(event_name, [])
if not isinstance(entries, list):
    print(f"error: {settings_path} hooks.{event_name} is not a list", file=sys.stderr)
    sys.exit(1)

def matcher_has_our_command(matcher):
    if not isinstance(matcher, dict):
        return False
    for h in matcher.get("hooks", []) or []:
        if isinstance(h, dict) and "peer-inbox-inject.sh" in (h.get("command") or ""):
            return True
    return False

our_block = {
    "hooks": [
        {"type": "command", "command": hook_command, "timeout": hook_timeout}
    ]
}

already_installed = any(matcher_has_our_command(m) for m in entries)
if already_installed:
    print(f"current: {settings_path}")
else:
    entries.append(our_block)
    hooks[event_name] = entries
    settings_path.write_text(json.dumps(data, indent=2) + "\n")
    print(f"installed: {settings_path} ({event_name} hook)")
PY
}

# remove_hook_json is the generic uninstaller paired with merge_hook_json.
# Usage: remove_hook_json <settings_path> <event_name> <timestamp>
remove_hook_json() {
  local settings="$1"
  local event_name="$2"
  local timestamp="$3"

  if [[ ! -f "$settings" ]]; then
    echo "missing: $settings"
    return
  fi

  cp "$settings" "${settings}.bak.${timestamp}"

  SETTINGS_PATH="$settings" EVENT_NAME="$event_name" python3 <<'PY'
import json
import os
import sys
from pathlib import Path

settings_path = Path(os.environ["SETTINGS_PATH"])
event_name = os.environ["EVENT_NAME"]
try:
    data = json.loads(settings_path.read_text())
except json.JSONDecodeError as e:
    print(f"error: {settings_path} is not valid JSON: {e}", file=sys.stderr)
    sys.exit(1)

hooks = data.get("hooks") or {}
entries = hooks.get(event_name) or []
if not isinstance(entries, list):
    print(f"warn: {event_name} is not a list; skipping")
    sys.exit(0)

def is_our_hook(h):
    return isinstance(h, dict) and "peer-inbox-inject.sh" in (h.get("command") or "")

touched = False
new_entries = []
for matcher in entries:
    if not isinstance(matcher, dict):
        new_entries.append(matcher)
        continue
    inner = matcher.get("hooks") or []
    if not isinstance(inner, list):
        new_entries.append(matcher)
        continue
    kept_inner = [h for h in inner if not is_our_hook(h)]
    if len(kept_inner) == len(inner):
        new_entries.append(matcher)
        continue
    touched = True
    if kept_inner:
        new_matcher = dict(matcher)
        new_matcher["hooks"] = kept_inner
        new_entries.append(new_matcher)

if not touched:
    print(f"no managed block: {settings_path}")
    sys.exit(0)

if new_entries:
    hooks[event_name] = new_entries
else:
    hooks.pop(event_name, None)
    if not hooks:
        data.pop("hooks", None)

settings_path.write_text(json.dumps(data, indent=2) + "\n")
print(f"uninstalled: {settings_path} ({event_name} hook)")
PY
}

# enable_codex_hooks_flag appends `[features] codex_hooks = true` to
# ~/.codex/config.toml if not already present. Codex requires the feature
# flag in addition to hooks.json for UserPromptSubmit hooks to fire. The
# edit is idempotent: skipped if `codex_hooks = true` is already set.
enable_codex_hooks_flag() {
  local config="$1"
  local timestamp="$2"

  mkdir -p "$(dirname "$config")"

  CONFIG_PATH="$config" TS="$timestamp" python3 <<'PY'
import os
import re
from pathlib import Path

config_path = Path(os.environ["CONFIG_PATH"])
existing = config_path.read_text() if config_path.exists() else ""

# Already enabled? Match `codex_hooks = true` in any [features] section
# (naive but safe: the key is unique and only documented under [features]).
if re.search(r'(?m)^\s*codex_hooks\s*=\s*true\s*$', existing):
    print(f"current: {config_path} ([features] codex_hooks already true)")
    raise SystemExit(0)

# Back up before modifying.
if config_path.exists():
    config_path.with_suffix(f".toml.bak.{os.environ['TS']}").write_text(existing)

# Append a [features] block. If one already exists without codex_hooks,
# we still append a new block — TOML allows it. Cleaner than parsing.
appended = existing
if appended and not appended.endswith("\n"):
    appended += "\n"
appended += "\n[features]\ncodex_hooks = true\n"
config_path.write_text(appended)
print(f"enabled: {config_path} ([features] codex_hooks = true)")
PY
}

# disable_codex_hooks_flag removes the `codex_hooks = true` line from
# ~/.codex/config.toml on uninstall. Only removes the exact line; does
# not tear down a user-authored [features] block.
disable_codex_hooks_flag() {
  local config="$1"
  local timestamp="$2"

  if [[ ! -f "$config" ]]; then
    return
  fi

  CONFIG_PATH="$config" TS="$timestamp" python3 <<'PY'
import os
import re
from pathlib import Path

config_path = Path(os.environ["CONFIG_PATH"])
existing = config_path.read_text()

if not re.search(r'(?m)^\s*codex_hooks\s*=\s*true\s*$', existing):
    print(f"no managed line: {config_path}")
    raise SystemExit(0)

config_path.with_suffix(f".toml.bak.{os.environ['TS']}").write_text(existing)

# Remove the codex_hooks line + a possibly-now-empty [features] block we
# authored. Conservative: only strip [features]\ncodex_hooks = true\n
# when those two lines are adjacent and [features] has no other keys.
cleaned = re.sub(
    r'\n\[features\]\ncodex_hooks\s*=\s*true\s*\n',
    '\n',
    existing,
)
# Also handle the case where our block is at the start of file with no
# leading newline.
cleaned = re.sub(
    r'^\[features\]\ncodex_hooks\s*=\s*true\s*\n',
    '',
    cleaned,
)
# And the leftover-line case if the [features] block had other keys and
# only codex_hooks should be removed.
cleaned = re.sub(
    r'(?m)^\s*codex_hooks\s*=\s*true\s*\n',
    '',
    cleaned,
)
config_path.write_text(cleaned)
print(f"disabled: {config_path} ([features] codex_hooks removed)")
PY
}

mkdir -p "$HOME/.claude" "$HOME/.codex" "$HOME/.gemini"

case "$MODE" in
  install)
    claude_rendered="$(mktemp)"
    codex_rendered="$(mktemp)"
    gemini_rendered="$(mktemp)"
    claude_block="$(mktemp)"
    codex_block="$(mktemp)"
    gemini_block="$(mktemp)"

    render_template "$PROJECT_ROOT/templates/CLAUDE.md" > "$claude_rendered"
    render_template "$PROJECT_ROOT/templates/AGENTS.md" > "$codex_rendered"
    render_template "$PROJECT_ROOT/templates/GEMINI.md" > "$gemini_rendered"
    render_block "$PROJECT_ROOT/templates/CLAUDE.md" > "$claude_block"
    render_block "$PROJECT_ROOT/templates/AGENTS.md" > "$codex_block"
    render_block "$PROJECT_ROOT/templates/GEMINI.md" > "$gemini_block"

    [[ -s "$PROJECT_ROOT/docs/GLOBAL-PROTOCOL.md" ]] || err "missing or empty protocol doc: $PROJECT_ROOT/docs/GLOBAL-PROTOCOL.md"

    write_installed_file "$CLAUDE_TARGET" "$claude_block" "$claude_rendered" "# Global Claude Collaboration Defaults"
    write_installed_file "$CODEX_TARGET" "$codex_block" "$codex_rendered" "# Global Codex Collaboration Defaults"
    write_installed_file "$GEMINI_TARGET" "$gemini_block" "$gemini_rendered" "# Global Gemini Collaboration Defaults"
    write_command_file "$COMMAND_TARGET" "$PROJECT_ROOT/scripts/agent-collab"

    # Peer-inbox: install python helper + channel + hook script to stable home paths.
    install_peer_inbox_file "$PROJECT_ROOT/scripts/peer-inbox-db.py" "$PEER_INBOX_DB_SCRIPT"
    install_peer_inbox_file "$PROJECT_ROOT/scripts/peer-inbox-channel.py" "$PEER_INBOX_CHANNEL_SCRIPT"
    install_peer_inbox_file "$PROJECT_ROOT/hooks/peer-inbox-inject.sh" "$PEER_INBOX_HOOK_SCRIPT"
    merge_claude_hook "$CLAUDE_SETTINGS" "$PEER_INBOX_HOOK_SCRIPT" "$TIMESTAMP"
    # Register the same unified hook with Codex and Gemini if their homes
    # exist (detected via $HOME/.{codex,gemini} already ensured by mkdir
    # above). The hook script is schema-agnostic — all three CLIs parse
    # identically.
    if [[ -d "$HOME/.codex" ]]; then
      # Codex timeout unit: seconds (default 600s per its docs).
      merge_hook_json "$CODEX_HOOKS" "UserPromptSubmit" "$PEER_INBOX_HOOK_SCRIPT" 5 "$TIMESTAMP"
      enable_codex_hooks_flag "$CODEX_CONFIG" "$TIMESTAMP"
    fi
    if [[ -d "$HOME/.gemini" ]]; then
      # Gemini timeout unit: MILLISECONDS (default 60000ms per its docs).
      # probe-J on 2026-04-18 confirmed Gemini kills hooks at 5ms when the
      # value is 5 (the bare number it shares with Claude/Codex sec-semantics).
      # 60000ms = 60s matches Claude's documented default and gives ample
      # headroom for the ~5-10ms warm-path / ~300ms cold-path hook budget.
      merge_hook_json "$GEMINI_SETTINGS" "BeforeAgent" "$PEER_INBOX_HOOK_SCRIPT" 60000 "$TIMESTAMP"
    fi
    merge_user_mcp_server "$PEER_INBOX_CHANNEL_SCRIPT" "$TIMESTAMP"

    # Topic 3 v0: install daemon binaries + config dir. Order: Go binaries
    # first (needed before anyone invokes them), then config dir (operator
    # template). Binaries build-and-install via `go build`; skip
    # gracefully if the go toolchain isn't available (install-global-
    # protocol must remain runnable without go; only the daemon-mode
    # features degrade).
    install_go_binary "$PEER_INBOX_DAEMON_BIN" "daemon" "agent-collab-daemon"
    install_go_binary "$PEER_INBOX_GO_CLI" "peer-inbox" "peer-inbox Go CLI"
    install_daemon_config_dir

    # Slash commands: /agent-collab and /peer in Claude Code.
    for cmd in "${SLASH_COMMANDS[@]}"; do
      install_slash_command "$PROJECT_ROOT/commands/$cmd" "$CLAUDE_COMMANDS_DIR/$cmd"
    done

    # Skills: natural-language entry points ("install agent-collab").
    for skill in "${SKILLS[@]}"; do
      install_skill_dir "$PROJECT_ROOT/skills/$skill" "$CLAUDE_SKILLS_DIR/$skill"
    done

    rm -f "$claude_rendered" "$codex_rendered" "$gemini_rendered" "$claude_block" "$codex_block" "$gemini_block"

    echo
    echo "protocol reference:"
    echo "  $PROJECT_ROOT/docs/GLOBAL-PROTOCOL.md"
    echo "global command:"
    echo "  $COMMAND_TARGET"
    echo "peer-inbox:"
    echo "  helper:  $PEER_INBOX_DB_SCRIPT"
    echo "  hook:    $PEER_INBOX_HOOK_SCRIPT"
    echo "           registered in:"
    echo "             $CLAUDE_SETTINGS (UserPromptSubmit)"
    [[ -f "$CODEX_HOOKS" ]] && echo "             $CODEX_HOOKS (UserPromptSubmit)"
    [[ -f "$GEMINI_SETTINGS" ]] && echo "             $GEMINI_SETTINGS (BeforeAgent)"
    echo "  channel: $PEER_INBOX_CHANNEL_SCRIPT (launch claude with --dangerously-load-development-channels server:peer-inbox)"
    echo "  db:      $PEER_INBOX_HOME/sessions.db (created on first session register)"
    if [[ -x "$PEER_INBOX_DAEMON_BIN" || -x "$PEER_INBOX_GO_CLI" ]]; then
      echo "auto-reply daemon (Topic 3 v0):"
      [[ -x "$PEER_INBOX_DAEMON_BIN" ]] && echo "  daemon:    $PEER_INBOX_DAEMON_BIN"
      [[ -x "$PEER_INBOX_GO_CLI"     ]] && echo "  peer-inbox: $PEER_INBOX_GO_CLI (daemon-claim / daemon-complete / daemon-sweep)"
      echo "  configs:   $PEER_INBOX_DAEMONS_DIR/ (copy example.json.disabled → <label>.json to manage a label)"
      echo "  operator:  $PROJECT_ROOT/docs/DAEMON-OPERATOR-GUIDE.md"
      echo "  sweeper:   run \`peer-inbox daemon-sweep\` on a timer (systemd-user, launchd, or cron — see operator guide)"
    fi
    echo "slash commands:"
    for cmd in "${SLASH_COMMANDS[@]}"; do
      echo "  $CLAUDE_COMMANDS_DIR/$cmd"
    done
    echo "skills:"
    for skill in "${SKILLS[@]}"; do
      echo "  $CLAUDE_SKILLS_DIR/$skill/SKILL.md"
    done
    if [[ ":$PATH:" != *":$BIN_DIR:"* ]]; then
      echo "warn: $BIN_DIR is not on PATH"
    fi
    ;;
  --uninstall|uninstall)
    remove_installed_block "$CLAUDE_TARGET"
    remove_installed_block "$CODEX_TARGET"
    remove_installed_block "$GEMINI_TARGET"
    remove_managed_command "$COMMAND_TARGET"
    remove_claude_hook "$CLAUDE_SETTINGS" "$TIMESTAMP"
    if [[ -f "$CODEX_HOOKS" ]]; then
      remove_hook_json "$CODEX_HOOKS" "UserPromptSubmit" "$TIMESTAMP"
    fi
    if [[ -f "$CODEX_CONFIG" ]]; then
      disable_codex_hooks_flag "$CODEX_CONFIG" "$TIMESTAMP"
    fi
    if [[ -f "$GEMINI_SETTINGS" ]]; then
      remove_hook_json "$GEMINI_SETTINGS" "BeforeAgent" "$TIMESTAMP"
    fi
    remove_user_mcp_server "$TIMESTAMP"
    remove_peer_inbox_file "$PEER_INBOX_HOOK_SCRIPT"
    remove_peer_inbox_file "$PEER_INBOX_CHANNEL_SCRIPT"
    remove_peer_inbox_file "$PEER_INBOX_DB_SCRIPT"
    # Topic 3 v0: remove daemon binaries + example config. Operator-
    # authored daemon configs in $PEER_INBOX_DAEMONS_DIR are preserved
    # — uninstall mirrors the sessions.db treatment (user data stays).
    remove_go_binary "$PEER_INBOX_DAEMON_BIN"
    remove_go_binary "$PEER_INBOX_GO_CLI"
    remove_daemon_config_dir
    for cmd in "${SLASH_COMMANDS[@]}"; do
      remove_slash_command "$CLAUDE_COMMANDS_DIR/$cmd"
    done
    for skill in "${SKILLS[@]}"; do
      remove_skill_dir "$CLAUDE_SKILLS_DIR/$skill"
    done
    # Intentional: never remove $PEER_INBOX_HOME/sessions.db — user data.
    ;;
  *)
    err "usage: $(basename "$0") [install|uninstall|--uninstall]"
    ;;
esac
