#!/usr/bin/env bash
set -euo pipefail

PROJECT_ROOT="$(cd "$(dirname "$0")/.." && pwd)"
CLAUDE_TARGET="$HOME/.claude/CLAUDE.md"
CODEX_TARGET="$HOME/.codex/AGENTS.md"
GEMINI_TARGET="$HOME/.gemini/GEMINI.md"
BIN_DIR="${AGENT_COLLAB_BIN_DIR:-$HOME/.local/bin}"
COMMAND_TARGET="$BIN_DIR/agent-collab"
START_MARKER="<!-- BEGIN agent-collaboration -->"

PEER_INBOX_HOME="$HOME/.agent-collab"
PEER_INBOX_DB_SCRIPT="$PEER_INBOX_HOME/scripts/peer-inbox-db.py"
PEER_INBOX_HOOK_SCRIPT="$PEER_INBOX_HOME/hooks/peer-inbox-inject.sh"
PEER_INBOX_DB_PATH="${AGENT_COLLAB_INBOX_DB:-$PEER_INBOX_HOME/sessions.db}"
CLAUDE_SETTINGS="$HOME/.claude/settings.json"
CODEX_HOOKS="$HOME/.codex/hooks.json"
CODEX_CONFIG="$HOME/.codex/config.toml"
GEMINI_SETTINGS="$HOME/.gemini/settings.json"
PEER_INBOX_SQLITE_MIN="3.35.0"
TESTED_CLAUDE_VERSION="2.1.78 (Claude Code)"
TESTED_CODEX_VERSION="codex-cli 0.115.0"
TESTED_GEMINI_VERSION="@google/gemini-cli 0.38.1"
FAILURES=0
WARNINGS=0
PASSES=0

pass() {
  echo "PASS: $*"
  PASSES=$((PASSES + 1))
}

warn() {
  echo "WARN: $*"
  WARNINGS=$((WARNINGS + 1))
}

block() {
  echo "BLOCK: $*"
  FAILURES=$((FAILURES + 1))
}

extract_protocol_reference() {
  local path="$1"
  awk '
    /^Protocol reference:/ { capture = 1; next }
    capture && /^- `/ {
      line = $0
      sub(/^- `/, "", line)
      sub(/`$/, "", line)
      print line
      exit
    }
    capture && NF == 0 { exit }
  ' "$path"
}

check_target() {
  local label="$1"
  local path="$2"
  local protocol_path

  if [[ ! -f "$path" ]]; then
    block "$label file is missing: $path"
    return
  fi

  pass "$label file exists: $path"

  if grep -Fq "$START_MARKER" "$path"; then
    pass "$label file contains this project's managed block"
  else
    warn "$label file does not contain this project's managed block"
  fi

  protocol_path="$(extract_protocol_reference "$path" || true)"
  if [[ -z "$protocol_path" ]]; then
    warn "$label file does not expose a protocol reference path"
    return
  fi

  if [[ -f "$protocol_path" ]]; then
    pass "$label protocol reference exists: $protocol_path"
  else
    warn "$label protocol reference is stale or missing: $protocol_path"
  fi
}

check_temp_dir() {
  local temp_dir="${TMPDIR:-/tmp}"
  local probe=""

  probe="$(mktemp "${temp_dir%/}/agent-collaboration-doctor.XXXXXX" 2>/dev/null || true)"
  if [[ -n "$probe" && -f "$probe" ]]; then
    rm -f "$probe"
    pass "temp directory is writable: $temp_dir"
  else
    warn "temp directory is not writable or is full: $temp_dir"
  fi
}

check_claude_cli() {
  local claude_help actual_version

  if ! command -v claude >/dev/null 2>&1; then
    block "claude CLI is not installed or not on PATH"
    return
  fi

  pass "claude CLI found: $(command -v claude)"
  actual_version="$(claude --version)"
  pass "claude version: $actual_version"
  pass "last tested Claude baseline: $TESTED_CLAUDE_VERSION"

  if [[ "$actual_version" == "$TESTED_CLAUDE_VERSION" ]]; then
    pass "claude version matches last tested baseline"
  else
    warn "claude version differs from last tested baseline; revalidate manual trigger patterns if behavior drift appears"
  fi

  claude_help="$(claude --help 2>/dev/null || true)"

  if [[ "$claude_help" == *"-p, --print"* ]]; then
    pass "claude supports non-interactive print mode"
  else
    block "claude help does not advertise -p/--print"
  fi

  if [[ "$claude_help" == *"--permission-mode"* ]]; then
    pass "claude supports permission-mode selection"
  else
    warn "claude help does not advertise --permission-mode; manual trigger guidance may need adjustment"
  fi
}

check_codex_cli() {
  local codex_help codex_exec_help actual_version

  if ! command -v codex >/dev/null 2>&1; then
    block "codex CLI is not installed or not on PATH"
    return
  fi

  pass "codex CLI found: $(command -v codex)"
  actual_version="$(codex --version)"
  pass "codex version: $actual_version"
  pass "last tested Codex baseline: $TESTED_CODEX_VERSION"

  if [[ "$actual_version" == "$TESTED_CODEX_VERSION" ]]; then
    pass "codex version matches last tested baseline"
  else
    warn "codex version differs from last tested baseline; revalidate manual trigger patterns if behavior drift appears"
  fi

  codex_help="$(codex --help 2>/dev/null || true)"
  codex_exec_help="$(codex exec --help 2>/dev/null || true)"

  if [[ "$codex_help" == *$'\n  exec'* || "$codex_help" == *$'\n  exec '* ]]; then
    pass "codex supports exec mode"
  else
    block "codex help does not advertise exec mode"
  fi

  if [[ "$codex_exec_help" == *"-C, --cd"* ]]; then
    pass "codex exec supports selecting a working directory"
  else
    warn "codex exec help does not advertise -C/--cd; manual trigger guidance may need adjustment"
  fi

  if [[ "$codex_exec_help" == *"-s, --sandbox"* && "$codex_exec_help" == *"read-only"* ]]; then
    pass "codex exec supports read-only sandbox selection"
  else
    warn "codex exec help does not clearly advertise read-only sandbox support"
  fi

  if [[ "$codex_exec_help" == *"-o, --output-last-message"* ]]; then
    pass "codex exec supports output capture to a file"
  else
    warn "codex exec help does not advertise -o/--output-last-message; stdout redirection may be required instead"
  fi

  if [[ "$codex_exec_help" == *"read from stdin"* ]]; then
    pass "codex exec supports stdin prompt delivery"
  else
    warn "codex exec help does not advertise stdin prompt delivery; argv fallback may be required instead"
  fi
}

check_gemini_cli() {
  local gemini_help actual_version

  if ! command -v gemini >/dev/null 2>&1; then
    block "gemini CLI is not installed or not on PATH"
    return
  fi

  pass "gemini CLI found: $(command -v gemini)"
  actual_version="$(gemini --version 2>/dev/null | head -1)"
  pass "gemini version: $actual_version"
  pass "last tested Gemini baseline: $TESTED_GEMINI_VERSION"

  gemini_help="$(gemini --help 2>/dev/null || true)"

  if [[ "$gemini_help" == *"-p, --prompt"* ]]; then
    pass "gemini supports non-interactive prompt mode"
  else
    block "gemini help does not advertise -p/--prompt"
  fi

  if [[ "$gemini_help" == *"--approval-mode"* ]]; then
    pass "gemini supports approval-mode selection"
  else
    warn "gemini help does not advertise --approval-mode; manual trigger guidance may need adjustment"
  fi

  if [[ "$gemini_help" == *"-o, --output-format"* ]]; then
    pass "gemini supports output format selection"
  else
    warn "gemini help does not advertise -o/--output-format"
  fi
}

check_global_command() {
  local agent_help

  if [[ -x "$COMMAND_TARGET" ]]; then
    pass "global command installed: $COMMAND_TARGET"
  else
    warn "global command is not installed at $COMMAND_TARGET"
  fi

  if ! command -v agent-collab >/dev/null 2>&1; then
    warn "agent-collab is not on PATH"
    return
  fi

  pass "agent-collab found: $(command -v agent-collab)"

  agent_help="$(agent-collab --help 2>/dev/null || true)"

  if [[ "$agent_help" == *"agent-collab challenge"* && "$agent_help" == *"agent-collab verify"* ]]; then
    pass "agent-collab exposes challenge and verify subcommands"
  else
    warn "agent-collab help output is missing expected subcommands"
  fi

  if grep -Fq -- "--timeout-seconds" <<<"$agent_help"; then
    pass "agent-collab advertises timeout override support"
  else
    warn "agent-collab help output is missing --timeout-seconds"
  fi
}

check_timeout_backend() {
  if command -v timeout >/dev/null 2>&1; then
    pass "timeout backend available: $(command -v timeout)"
    return
  fi

  if command -v gtimeout >/dev/null 2>&1; then
    pass "timeout backend available: $(command -v gtimeout)"
    return
  fi

  if command -v python3 >/dev/null 2>&1; then
    pass "timeout backend fallback available via python3: $(command -v python3)"
    return
  fi

  block "no timeout backend available for agent-collab; install timeout/gtimeout or python3"
}

check_project() {
  if [[ -f "$PROJECT_ROOT/docs/GLOBAL-PROTOCOL.md" ]]; then
    pass "project protocol doc exists"
  else
    block "project protocol doc is missing: $PROJECT_ROOT/docs/GLOBAL-PROTOCOL.md"
  fi

  if [[ -x "$PROJECT_ROOT/scripts/install-global-protocol" ]]; then
    pass "installer is executable"
  else
    warn "installer is not executable"
  fi
}

check_peer_inbox() {
  echo
  echo "peer-inbox checks:"

  if ! command -v python3 >/dev/null 2>&1; then
    block "python3 not on PATH (required by peer-inbox)"
    return
  fi
  pass "python3 found: $(command -v python3)"

  local py_version py_sqlite
  py_version="$(python3 -c 'import sys; print(".".join(str(x) for x in sys.version_info[:3]))' 2>/dev/null || echo unknown)"
  if python3 -c "import sys; sys.exit(0 if sys.version_info[:2] >= (3, 9) else 1)"; then
    pass "python version $py_version meets peer-inbox minimum 3.9"
  else
    block "python version $py_version below peer-inbox minimum 3.9"
    return
  fi

  py_sqlite="$(python3 -c 'import sqlite3; print(sqlite3.sqlite_version)' 2>/dev/null || echo unknown)"
  if [[ "$py_sqlite" == "unknown" ]]; then
    block "python3 sqlite3 module is not usable"
    return
  fi

  # Version gate: need >= 3.35.0 for UPDATE ... RETURNING
  if python3 -c "
import sys
cur = tuple(int(p) for p in '$py_sqlite'.split('.'))
need = tuple(int(p) for p in '$PEER_INBOX_SQLITE_MIN'.split('.'))
sys.exit(0 if cur >= need else 1)
"; then
    pass "python-linked sqlite $py_sqlite meets peer-inbox minimum $PEER_INBOX_SQLITE_MIN"
  else
    block "python-linked sqlite $py_sqlite below minimum $PEER_INBOX_SQLITE_MIN (needed for UPDATE...RETURNING)"
  fi

  if [[ -r "$PEER_INBOX_DB_SCRIPT" ]]; then
    pass "peer-inbox helper installed: $PEER_INBOX_DB_SCRIPT"
  else
    warn "peer-inbox helper not installed at $PEER_INBOX_DB_SCRIPT (run install-global-protocol)"
  fi

  if [[ -x "$PEER_INBOX_HOOK_SCRIPT" ]]; then
    pass "peer-inbox hook installed and executable: $PEER_INBOX_HOOK_SCRIPT"
  else
    warn "peer-inbox hook not installed/executable at $PEER_INBOX_HOOK_SCRIPT"
  fi

  local db_parent
  db_parent="$(dirname "$PEER_INBOX_DB_PATH")"
  if [[ -d "$db_parent" && -w "$db_parent" ]]; then
    pass "peer-inbox DB parent dir writable: $db_parent"
  elif [[ ! -d "$db_parent" ]]; then
    warn "peer-inbox DB parent dir missing: $db_parent (created on first session register)"
  else
    block "peer-inbox DB parent dir not writable: $db_parent"
  fi

  check_hook_registration "Claude" "$CLAUDE_SETTINGS" "UserPromptSubmit"
  check_hook_registration "Codex" "$CODEX_HOOKS" "UserPromptSubmit"
  check_hook_registration "Gemini" "$GEMINI_SETTINGS" "BeforeAgent"

  # Codex additionally requires the feature flag to honor its hooks.json.
  if [[ -f "$CODEX_CONFIG" ]]; then
    if grep -qE '^\s*codex_hooks\s*=\s*true\s*$' "$CODEX_CONFIG" 2>/dev/null; then
      pass "Codex codex_hooks feature flag enabled in $CODEX_CONFIG"
    else
      warn "Codex codex_hooks feature flag missing from $CODEX_CONFIG — hooks.json will be ignored (run install-global-protocol)"
    fi
  elif [[ -f "$CODEX_HOOKS" ]]; then
    warn "Codex hooks.json present but $CODEX_CONFIG missing — feature flag required for hooks to fire"
  fi

  # Topic 3 v0 auto-reply daemon — optional. Only warn if a daemon
  # config file exists (operator has committed to using the daemon) but
  # the binaries are missing. Otherwise stay silent: daemon is additive,
  # not required for hook-based peer-inbox coordination.
  local bin_dir="${AGENT_COLLAB_BIN_DIR:-$HOME/.local/bin}"
  local daemon_bin="$bin_dir/agent-collab-daemon"
  local go_cli="$bin_dir/peer-inbox"
  local daemons_dir="$HOME/.agent-collab/daemons"

  local has_any_daemon_config=0
  if [[ -d "$daemons_dir" ]]; then
    # Count *.json files excluding the .json.disabled example.
    shopt -s nullglob
    local -a cfgs=( "$daemons_dir"/*.json )
    shopt -u nullglob
    if (( ${#cfgs[@]} > 0 )); then
      has_any_daemon_config=1
    fi
  fi

  if [[ -x "$daemon_bin" ]]; then
    pass "Topic 3 daemon binary installed: $daemon_bin"
  elif (( has_any_daemon_config )); then
    warn "daemon config present in $daemons_dir but $daemon_bin missing — run install-global-protocol to build + install"
  fi

  if [[ -x "$go_cli" ]]; then
    pass "Topic 3 peer-inbox Go CLI installed: $go_cli"
  elif (( has_any_daemon_config )); then
    warn "daemon config present in $daemons_dir but $go_cli missing — spawned agents won't be able to call daemon-complete"
  fi

  if (( has_any_daemon_config )) && [[ ! -x "$daemon_bin" || ! -x "$go_cli" ]]; then
    warn "see docs/DAEMON-OPERATOR-GUIDE.md for daemon setup + sweeper-timer configuration"
  fi
}

# check_hook_registration verifies a hooks.<event>[].hooks[] entry pointing
# at peer-inbox-inject.sh exists in the given settings file. Uniform across
# Claude / Codex / Gemini since all three share the same JSON shape.
check_hook_registration() {
  local label="$1"
  local settings_path="$2"
  local event_name="$3"

  if [[ ! -f "$settings_path" ]]; then
    warn "$label hook config not found at $settings_path — $event_name hook cannot be registered"
    return
  fi

  if SETTINGS_PATH="$settings_path" EVENT_NAME="$event_name" python3 -c '
import json, os, sys
path = os.environ["SETTINGS_PATH"]
event = os.environ["EVENT_NAME"]
try:
    d = json.load(open(path))
except Exception as e:
    print(e, file=sys.stderr); sys.exit(2)
entries = (d.get("hooks") or {}).get(event) or []
found = any(
    "peer-inbox-inject.sh" in (h.get("command") or "")
    for m in entries if isinstance(m, dict)
    for h in (m.get("hooks") or []) if isinstance(h, dict)
)
sys.exit(0 if found else 1)
' 2>/dev/null; then
    pass "peer-inbox $event_name hook registered in $settings_path ($label)"
  else
    warn "peer-inbox $event_name hook not registered in $settings_path ($label) — run install-global-protocol"
  fi
}

check_project
check_temp_dir
check_target "Claude" "$CLAUDE_TARGET"
check_target "Codex" "$CODEX_TARGET"
check_global_command
check_timeout_backend
check_claude_cli
check_codex_cli
check_target "Gemini" "$GEMINI_TARGET"
check_gemini_cli
check_peer_inbox

echo
echo "Summary: $PASSES PASS, $WARNINGS WARN, $FAILURES BLOCK"

if (( FAILURES > 0 )); then
  exit 1
fi
